{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://uluos.io/schemas/capability.json",
  "title": "UluOS Capability Definition",
  "description": "Schema for a single capability exposed by an MCP service",
  "type": "object",
  "required": ["name", "service", "tool", "readOnly"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Fully qualified capability name: service.tool",
      "pattern": "^[a-z][a-z0-9-]*\\.[a-z][a-zA-Z0-9_]*$"
    },
    "service": {
      "type": "string",
      "description": "Service that owns this capability"
    },
    "tool": {
      "type": "string",
      "description": "Tool name within the service"
    },
    "description": {
      "type": "string"
    },
    "chains": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Blockchain networks this capability operates on"
    },
    "readOnly": {
      "type": "boolean",
      "description": "True if this capability only reads data"
    },
    "requiresAuth": {
      "type": "boolean",
      "default": false
    },
    "requiresSigning": {
      "type": "boolean",
      "default": false,
      "description": "True if the gateway must route through WalletMCP"
    },
    "requiresBroadcast": {
      "type": "boolean",
      "default": false,
      "description": "True if the gateway must route through BroadcastMCP"
    },
    "requiresPayment": {
      "type": "boolean",
      "default": false,
      "description": "True if x402 payment is required"
    },
    "pricingTier": {
      "type": "string",
      "enum": ["free", "standard", "premium", "enterprise"],
      "default": "free"
    },
    "parameters": {
      "type": "object",
      "description": "JSON Schema for the capability's input parameters",
      "additionalProperties": true
    },
    "response": {
      "type": "object",
      "description": "JSON Schema for the capability's response data",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
