# UluOS Local Development Environment
# Copy to .env and fill in real values

# --- Gateway ---
GATEWAY_PORT=3000
ULUOS_API_KEY=change-me-in-production

# --- Service URLs (internal Docker network) ---
CORE_MCP_URL=http://core-mcp:3001
WALLET_MCP_URL=http://wallet-mcp:3002
BROADCAST_MCP_URL=http://broadcast-mcp:3003
VOI_MCP_URL=http://voi-mcp:3004
ALGORAND_MCP_URL=http://algorand-mcp:3005
DORKFI_MCP_URL=http://dorkfi-mcp:3006
ENVOI_MCP_URL=http://envoi-mcp:3007
ARAMID_BRIDGE_MCP_URL=http://aramid-bridge-mcp:3008

# --- Service Images (override to use real images) ---
# CORE_MCP_IMAGE=ghcr.io/ulu/core-mcp:latest
# WALLET_MCP_IMAGE=ghcr.io/ulu/wallet-mcp:latest
# BROADCAST_MCP_IMAGE=ghcr.io/ulu/broadcast-mcp:latest
# VOI_MCP_IMAGE=ghcr.io/ulu/voi-mcp:latest
# ALGORAND_MCP_IMAGE=ghcr.io/ulu/algorand-mcp:latest
# DORKFI_MCP_IMAGE=ghcr.io/ulu/dorkfi-mcp:latest
# ENVOI_MCP_IMAGE=ghcr.io/ulu/envoi-mcp:latest
# ARAMID_BRIDGE_MCP_IMAGE=ghcr.io/ulu/aramid-bridge-mcp:latest

# --- Voi Node ---
VOI_ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
VOI_NETWORK=mainnet
# VOI_INDEXER_URL=
# VOI_INDEXER_TOKEN=

# --- Algorand Node ---
ALGORAND_ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
ALGORAND_NETWORK=mainnet
# ALGORAND_INDEXER_IMAGE=algorand/indexer:latest
# ALGORAND_ALGOD_IMAGE=algorand/algod:latest

# --- Node Images (override for specific versions) ---
# VOI_ALGOD_IMAGE=algorand/algod:latest
# ALGORAND_ALGOD_IMAGE=algorand/algod:latest
